# =============================
# App
# =============================
APP_NAME=GhanaXplore
APP_ENV=development
DEBUG=true
API_VERSION=v1
SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret
DB_AUTO_CREATE_TABLES=false
COMPOSE_PROJECT_NAME=ghanaxplore


# =============================
# Database
# =============================
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass
POSTGRES_DB=app_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://app_user:app_pass@postgres:5432/app_db

# =============================
# Redis
# =============================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_DB=0
REDIS_URL=redis://:redis_pass@redis:6379/0

# =============================
# RabbitMQ / Celery
# =============================
RABBITMQ_USER=app_rmq
RABBITMQ_PASS=rmq_pass
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
CELERY_BROKER_URL=amqp://app_rmq:rmq_pass@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:redis_pass@redis:6379/0

# =============================
# Security
# =============================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# =============================
# GhanaXplore Integrations
# =============================
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_BASE_URL=
SMS_PROVIDER=hubtel
SMS_API_KEY=
SMS_SENDER_ID=GhanaXplore
FCM_SERVER_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================
# Email / SMS
# =============================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=example_user
SMTP_PASSWORD=example_password
EMAIL_FROM=no-reply@example.com
SUPPORT_EMAIL=support@ghanaxplore.com

# =============================
# API / CORS
# =============================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# =============================
# Logging / Monitoring
# =============================
LOG_LEVEL=INFO
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000
LOGSTASH_HOST_PORT=5001
RATE_LIMIT_PER_MINUTE=60

# =============================
# File Upload
# =============================
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
